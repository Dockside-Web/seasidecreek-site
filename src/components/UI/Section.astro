---
interface Props {
  background?: "stone" | "white" | string;
  class?: string;
  id?: string;
}

const { background = "stone", class: className, id } = Astro.props;

// Map the simple names to the actual Tailwind classes
const bgMap: Record<string, string> = {
  stone: "bg-stone-50",
  white: "bg-white"
};

// Use the mapped class, or fall back to the string if it's a custom class
const bgClass = bgMap[background] || background;
---

<section class:list={["py-18", bgClass]}, id={id}>
  <div class:list={[
    "container px-12 max-w-6xl mx-auto sm:px-6 lg:px-8",
    className
  ]}>
    <slot />
  </div>
</section>