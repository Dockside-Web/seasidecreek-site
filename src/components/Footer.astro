---
import { Image } from "astro:assets";
import logoWhiteHorizontal from "../assets/logoWhiteHorizontal.svg";

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-primary text-white py-16">
  <div class="container mx-auto px-6 lg:px-8 max-w-5xl">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      <div>
        <Image src={logoWhiteHorizontal} alt="Seaside Creek Advisors Logo" class="w-1/2 h-auto" />
        <p class="text-slate-200/90 text-sm mt-3 leading-relaxed">
          Executive-level financial leadership for organizations that demand clarity and discipline.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-brand-accent mb-4">
          Navigation
        </h4>
        <nav class="flex flex-col gap-2">
          <a href="/" class="text-sm text-slate-200 hover:text-brand-accent transition-colors">Home</a>
          <a href="/#about" class="text-sm text-slate-200 hover:text-brand-accent transition-colors">About</a>
          <a href="/#contact" class="text-sm text-slate-200 hover:text-brand-accent transition-colors">Contact</a>
        </nav>
      </div>

      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-brand-accent mb-4">
          Connect
        </h4>
        <div class="flex flex-col gap-4">
          <a href="mailto:kevin@seasidecreek.com" class="inline-flex items-center gap-2 text-sm text-slate-200 hover:text-brand-accent transition-colors group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-brand-accent transition-colors">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            kevin@seasidecreek.com
          </a>
          <div class="inline-flex items-center gap-2 text-sm text-slate-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            Charleston, South Carolina
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8">
      <p class="text-xs text-white/40 text-center font-light">
        © {currentYear} Seaside Creek Advisors. All rights reserved.
      </p>
    </div>
  </div>
</footer>