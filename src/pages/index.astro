---
import { Image } from "astro:assets";
import PelicanImage from "../assets/pelican.jpg";
import Layout from "../layouts/Layout.astro";
import Section from "../components/UI/Section.astro";
import SectionHeader from "../components/UI/SectionHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import Button from "../components/Button.astro";

const pillars = [
  {
    title: "Fractional CFO Support",
    description: "CFO-level leadership for organizations requiring clarity in financial decision-making. We integrate seamlessly into your existing governance rhythms.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  {
    title: "Strategic Planning",
    description: "Bringing technical rigor to financial tradeoffs. We support discussions where governance, seasonality, or capital considerations add complexity.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`
  },
  {
    title: "Financial Continuity",
    description: "A financial partner providing continuity without full-time overhead. We focus on practical decision support that extends beyond basic reporting.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7 12 2"/></svg>`
  },
];

const metaDescription = "Seaside Creek Advisors provides fractional CFO leadership and strategic planning for growing organizations.";
---

<Layout description={metaDescription}>
  
  <section class="relative min-h-[75vh] md:min-h-[85vh] flex items-center justify-center overflow-hidden bg-slate-900">
    <img
      src="https://images.unsplash.com/photo-1533852990198-bdd4082bf8c0?q=80&w=1933&auto=format&fit=crop"
      alt="Serene maritime coastline"
      class="absolute inset-0 w-full h-full object-cover opacity-50 md:opacity-70"
    />
    <div class="absolute inset-0 bg-linear-to-b from-slate-900/90 via-slate-900/40 to-slate-900/90"></div>
    
    <div class="relative z-10 text-center max-w-4xl mx-auto px-6 pt-32 pb-12 md:py-20">
      <h1 class="text-3xl md:text-6xl font-serif font-bold text-white leading-tight mb-6 animate-fade-up">
        Executive Financial Leadership <span class="text-brand-accent italic font-light block md:inline">on your terms</span>
      </h1>
      <p class="text-base md:text-lg text-white/90 leading-relaxed max-w-2xl mx-auto mb-10 animate-fade-up" style="animation-delay: 0.2s;">
        Access seasoned CFO guidance for budgeting, capital planning, and strategic support. Delivered with the flexibility your organization needs.
      </p>
      <div class="animate-fade-up" style="animation-delay: 0.4s;">
        <Button href="#contact" variant="accent" size="md">
          Schedule a Consultation
        </Button>
      </div>
    </div>
</section>

  <Section background="white" id="about" class="overflow-x-hidden">
      <SectionHeader tagline="Our Mission" title="Strategic Financial Leadership">
        Seaside Creek Advisors provides CFO-level financial leadership to organizations that require clarity, discipline, and continuity in their decision-making. 
        We partner with leadership teams to help frame financial tradeoffs and strengthen planning processes through thoughtful analysis. 
        Our firm operates as a dedicated partner, integrating into your existing rhythm without the burden of full-time executive overhead. 
        We are committed to delivering the technical rigor and strategic training necessary for complex financial environments.
      </SectionHeader>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-12 items-center">
        <div class="flex flex-col gap-4">
  {pillars.map((p) => (
    <div class="group relative overflow-hidden bg-brand-secondary/10 border border-slate-100 rounded-lg p-5 md:p-6 hover:shadow-md transition-all duration-300">
      
      <div class="absolute top-0 left-0 w-full h-1 bg-brand-primary scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

      <div class="flex gap-4 items-center relative z-10">                
        <div class="shrink-0 w-10 h-10 rounded-full bg-white shadow-sm border border-slate-50 flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-colors text-brand-primary">
          <Fragment set:html={p.icon} />
        </div>
        <div>
          <h4 class="text-lg font-serif font-bold mb-1 italic text-slate-800">
            {p.title}
          </h4>
          <p class="text-slate-600 leading-snug text-sm">
            {p.description}
          </p>
        </div>
      </div>
    </div>
  ))}
</div>

        <div class="relative h-75 md:h-125 w-full">
          <Image
            src={PelicanImage} 
            alt="Seaside Creek Office Environment" 
            class="w-full h-full object-cover rounded-xl shadow-lg border border-slate-100"
          />
        </div>
      </div>
  </Section>

  <Section background="stone" id="contact" class="overflow-x-hidden">
      <SectionHeader tagline="Connect" title="Start the Conversation" />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <ContactForm /> 
        </div>

        <div class="lg:col-span-5 space-y-6 md:space-y-8 order-1 lg:order-2">
          <div>
            <h3 class="font-serif text-2xl font-semibold mb-3">Get in Touch</h3>
            <p class="text-slate-600 italic text-base md:text-lg">
              We welcome the opportunity to discuss how we can support your organization's financial leadership needs.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
            <a href="mailto:kevin@seasidecreek.com" class="flex items-center gap-4 group">
              <div class="w-12 h-12 shrink-0 rounded-full bg-white border border-slate-100 shadow-sm flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-all">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div class="overflow-hidden">
                <p class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">Email Us</p>
                <span class="text-sm md:text-base font-medium group-hover:text-brand-accent transition-colors truncate block">
                  kevin@seasidecreek.com
                </span>
              </div>
            </a>

            <a href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
              <div class="w-12 h-12 shrink-0 rounded-full bg-white border border-slate-100 shadow-sm flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-all">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
                </svg>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">Network</p>
                <span class="text-sm md:text-base font-medium group-hover:text-brand-accent transition-colors">
                  LinkedIn Profile
                </span>
              </div>
            </a>
          </div>
        </div>
      </div>
  </Section>
</Layout>

<style is:global>
  html, body {
    overflow-x: hidden;
    width: 100%;
  }

  html {
    scroll-behavior: smooth;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-up {
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>